{
  "@id": "http://localhost:8888/section-nav-test-page",
  "@type": "Document",
  "id": "section-nav-test-page",
  "title": "Section Nav Test Page",
  "description": "Fixture for sectionNav block tests. Three hand-added navItems plus a depth-2 listing that fetches /_test_data children.",
  "review_state": "published",
  "UID": "section-nav-test-page-uid",
  "is_folderish": false,
  "blocks": {
    "title-block": {
      "@type": "title"
    },
    "nav-1": {
      "@type": "sectionNav",
      "ariaLabel": "Section navigation",
      "placement": "sidebar",
      "blocks": {
        "item-self": {
          "@type": "navItem",
          "label": "This page",
          "href": [{ "@id": "/_test_data/section-nav-test-page" }],
          "level": 1
        },
        "item-test-page": {
          "@type": "navItem",
          "label": "Test Page",
          "href": [{ "@id": "/_test_data/test-page" }],
          "level": 1
        },
        "item-test-page-child": {
          "@type": "navItem",
          "label": "Test Page child link",
          "href": [{ "@id": "/_test_data/test-page/sub" }],
          "level": 2
        }
      },
      "items": {
        "items": ["item-self", "item-test-page", "item-test-page-child"]
      }
    },
    "nav-2": {
      "@type": "sectionNav",
      "ariaLabel": "Auto-populated nav",
      "placement": "top",
      "blocks": {
        "snav-listing": {
          "@type": "listing",
          "variation": "nav",
          "querystring": {
            "query": [
              {
                "i": "path",
                "o": "plone.app.querystring.operation.string.absolutePath",
                "v": "/_test_data"
              }
            ],
            "sort_on": "getObjPositionInParent",
            "depth": 1
          }
        }
      },
      "items": {
        "items": ["snav-listing"]
      }
    }
  },
  "blocks_layout": {
    "items": ["title-block", "nav-1", "nav-2"]
  },
  "allow_discussion": false,
  "exclude_from_nav": false,
  "created": "2025-01-01T12:00:00+00:00",
  "modified": "2025-01-01T12:00:00+00:00",
  "lock": {
    "locked": false,
    "stealable": true
  }
}
