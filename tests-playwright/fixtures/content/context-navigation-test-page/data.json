{
  "@id": "http://localhost:8888/context-navigation-test-page",
  "@type": "Document",
  "id": "context-navigation-test-page",
  "title": "Context Navigation Test Page",
  "description": "Fixture for contextNavigation block tests. Hand-added navItems plus listings auto-populated from path/depth queries.",
  "review_state": "published",
  "UID": "context-navigation-test-page-uid",
  "is_folderish": false,
  "blocks": {
    "title-block": {
      "@type": "title"
    },
    "nav-1": {
      "@type": "contextNavigation",
      "ariaLabel": "Section navigation",
      "expandCurrentOnly": false,
      "blocks": {
        "item-self": {
          "@type": "navItem",
          "label": "This page",
          "href": [{ "@id": "/_test_data/context-navigation-test-page" }]
        },
        "item-test-page": {
          "@type": "navItem",
          "label": "Test Page",
          "href": [{ "@id": "/_test_data/test-page" }]
        },
        "item-test-page-child": {
          "@type": "navItem",
          "label": "Test Page child link",
          "href": [{ "@id": "/_test_data/test-page/sub" }]
        }
      },
      "items": {
        "items": ["item-self", "item-test-page", "item-test-page-child"]
      }
    },
    "nav-2": {
      "@type": "contextNavigation",
      "ariaLabel": "Auto-populated nav",
      "blocks": {
        "snav-listing": {
          "@type": "listing",
          "variation": "navItem",
          "fieldMapping": {
            "@id": { "field": "href", "type": "link" },
            "title": { "field": "label" }
          },
          "querystring": {
            "query": [
              {
                "i": "path",
                "o": "plone.app.querystring.operation.string.absolutePath",
                "v": "/_test_data"
              }
            ],
            "sort_on": "getObjPositionInParent",
            "depth": 1
          }
        }
      },
      "items": {
        "items": ["snav-listing"]
      }
    },
    "nav-4": {
      "@type": "contextNavigation",
      "ariaLabel": "Multi-depth nav",
      "blocks": {
        "snav-4-listing": {
          "@type": "listing",
          "variation": "navItem",
          "fieldMapping": {
            "@id": { "field": "href", "type": "link" },
            "title": { "field": "label" }
          },
          "querystring": {
            "query": [
              {
                "i": "path",
                "o": "plone.app.querystring.operation.string.absolutePath",
                "v": "/_test_data/context-navigation-forced-folder"
              }
            ],
            "sort_on": "getObjPositionInParent",
            "depth": 2
          }
        }
      },
      "items": {
        "items": ["snav-4-listing"]
      }
    }
  },
  "blocks_layout": {
    "items": ["title-block", "nav-1", "nav-2", "nav-4"]
