{
  "@id": "/templates/footer-layout",
  "@type": "Document",
  "UID": "footer-layout-uid",
  "id": "footer-layout",
  "title": "Footer Layout",
  "description": "A simple layout template for footer blocks with fixed branding",
  "blocks": {
    "fixed-branding": {
      "@type": "slate",
      "fixed": true,
      "readOnly": true,
      "templateId": "resolveuid/footer-layout-uid",
      "slotId": "branding",
      "value": [
        {
          "type": "p",
          "children": [{ "text": "Footer Branding - Forced Layout" }]
        }
      ],
      "plaintext": "Footer Branding - Forced Layout"
    },
    "default-slot": {
      "@type": "slate",
      "templateId": "resolveuid/footer-layout-uid",
      "slotId": "default",
      "value": [
        {
          "type": "p",
          "children": [{ "text": "" }]
        }
      ],
      "plaintext": ""
    },
    "footer-cols": {
      "@type": "columns",
      "fixed": true,
      "readOnly": true,
      "templateId": "resolveuid/footer-layout-uid",
      "slotId": "footer-cols",
      "blocks": {
        "footer-col-1": {
          "@type": "column",
          "fixed": true,
          "readOnly": true,
          "templateId": "resolveuid/footer-layout-uid",
          "slotId": "footer-col-1",
          "blocks": {
            "footer-col-cell": {
              "@type": "slate",
              "fixed": true,
              "readOnly": true,
              "templateId": "resolveuid/footer-layout-uid",
              "slotId": "footer-col-cell",
              "value": [{ "type": "p", "children": [{ "text": "Footer Column Cell" }] }],
              "plaintext": "Footer Column Cell"
            }
          },
          "blocks_layout": { "items": ["footer-col-cell"] }
        }
      },
      "blocks_layout": { "columns": ["footer-col-1"] }
    }
  },
  "blocks_layout": {
    "items": ["fixed-branding", "footer-cols", "default-slot"]
  },
  "@components": {
    "actions": {
      "@id": "/templates/footer-layout/@actions",
      "object": [
        {
          "@id": "/templates/footer-layout/edit",
          "id": "edit",
          "title": "Edit"
        }
      ],
      "object_buttons": []
    },
    "breadcrumbs": {
      "@id": "/templates/footer-layout/@breadcrumbs",
      "items": [
        { "@id": "/templates", "title": "Templates" },
        { "@id": "/templates/footer-layout", "title": "Footer Layout" }
      ]
    }
  }
}
