      "placeholder": "schema",
      "tabs": [
        {
          "@id": "ref-listing-schema-javascript-bd0476",
          "label": "Schema",
          "language": "javascript",
          "code": "{\n  \"listing\": {\n    \"schemaEnhancer\": {\n      \"inheritSchemaFrom\": {\n        \"typeField\": \"variation\",\n        \"mappingField\": \"fieldMapping\",\n        \"defaultsField\": \"itemDefaults\",\n        \"filterConvertibleFrom\": \"@default\",\n        \"title\": \"Item Type\",\n        \"default\": \"summary\"\n      }\n    }\n  },\n  \"summary\": {\n    \"fieldMappings\": {\n      \"@default\": {\n        \"@id\": \"href\",\n        \"title\": \"title\",\n        \"description\": \"description\",\n        \"image\": \"image\"\n      }\n    },\n    \"blockSchema\": {\n      \"properties\": {\n        \"href\": {\n          \"title\": \"Link\",\n          \"widget\": \"url\"\n        },\n        \"title\": {\n          \"title\": \"Title\"\n        },\n        \"description\": {\n          \"title\": \"Description\",\n          \"widget\": \"textarea\"\n        },\n        \"image\": {\n          \"title\": \"Image\",\n          \"widget\": \"url\"\n        },\n        \"date\": {\n          \"title\": \"Date\",\n          \"widget\": \"date\"\n        }\n      }\n    }\n  },\n  \"default\": {\n    \"fieldMappings\": {\n      \"@default\": {\n        \"@id\": \"href\",\n        \"title\": \"title\",\n        \"description\": \"description\"\n      }\n    },\n    \"blockSchema\": {\n      \"properties\": {\n        \"href\": {\n          \"title\": \"Link\",\n          \"widget\": \"url\"\n        },\n        \"title\": {\n          \"title\": \"Title\"\n        },\n        \"description\": {\n          \"title\": \"Description\",\n          \"widget\": \"textarea\"\n        }\n      }\n    }\n  }\n}"
        }
      ]
    },
