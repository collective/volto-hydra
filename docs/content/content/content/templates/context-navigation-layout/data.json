{
  "@id": "/templates/context-navigation-layout",
  "@type": "Document",
  "UID": "context-navigation-layout-uid",
  "id": "context-navigation-layout",
  "review_state": "published",
  "title": "Context Navigation Layout",
  "description": "Forced layout for 3rd-level pages — injects a contextNavigation (auto-populated from sibling pages via listing+depth) above the page content.",
  "blocks": {
    "tpl-context-nav": {
      "@type": "contextNavigation",
      "fixed": true,
      "readOnly": true,
      "templateId": "/templates/context-navigation-layout",
      "templateInstanceId": "context-navigation-layout-def-instance",
      "slotId": "context-navigation",
      "ariaLabel": "In this section",
      "blocks": {
        "tpl-cnav-listing": {
          "@type": "listing",
          "variation": "navItem",
          "fixed": true,
          "readOnly": true,
          "templateId": "/templates/context-navigation-layout",
          "templateInstanceId": "context-navigation-layout-def-instance",
          "slotId": "context-navigation-listing",
          "fieldMapping": {
            "@id": { "field": "href", "type": "link" },
            "title": { "field": "label" }
          },
          "querystring": {
            "query": [
              {
                "i": "path",
                "o": "plone.app.querystring.operation.string.relativePath",
                "v": ".."
              },
              {
                "i": "portal_type",
                "o": "plone.app.querystring.operation.selection.none",
                "v": ["Image", "File"]
              },
              {
                "i": "exclude_from_nav",
                "o": "plone.app.querystring.operation.boolean.isFalse",
                "v": ""
              }
            ],
            "sort_on": "getObjPositionInParent",
            "depth": 4
          }
        }
      },
      "blocks_layout": {
        "items": ["tpl-cnav-listing"]
      }
    },
    "tpl-default-slot": {
      "@type": "slate",
      "templateId": "/templates/context-navigation-layout",
      "templateInstanceId": "context-navigation-layout-def-instance",
      "slotId": "default",
      "value": [
        {
          "type": "p",
          "children": [{ "text": "" }]
        }
      ],
      "plaintext": ""
    }
  },
  "blocks_layout": {
    "items": ["tpl-context-nav", "tpl-default-slot"]
  },
  "parent": {
    "@id": "/templates",
    "@type": "Folder",
    "UID": "tpl-folder-001",
    "description": "Layout and block templates",
    "title": "Templates",
    "type_title": "Page"
  },
  "@components": {
    "actions": {
      "@id": "/templates/context-navigation-layout/@actions",
      "object": [
        {
          "@id": "/templates/context-navigation-layout/edit",
          "id": "edit",
          "title": "Edit"
        }
      ],
      "object_buttons": []
    },
    "breadcrumbs": {
      "@id": "/templates/context-navigation-layout/@breadcrumbs",
      "items": [
        { "@id": "/templates", "title": "Templates" },
        { "@id": "/templates/context-navigation-layout", "title": "Context Navigation Layout" }
      ]
    }
  }
}
