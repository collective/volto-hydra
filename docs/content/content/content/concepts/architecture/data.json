    "title-1": {
      "@type": "title"
    },
    "intro-1": {
      "@type": "slate",
      "plaintext": "Instead of combining editing and rendering into one framework, Hydra separates them and uses an iframe bridge for two-way communication during editing.",
      "value": [
        {
          "children": [
            {
              "text": "Instead of combining editing and rendering into one framework and codebase, these are separated and during editing a two way communication channel is opened across an iframe so that the editing UI is no longer part of the frontend code. Instead a small JS file called hydra.js is included in your frontend during editing that handles the iframe bridge communication to Hydra which is running in the same browser window."
            }
          ],
          "type": "p"
        }
      ]
    },
    "sep-1": {
      "@type": "separator",
      "styles": {
        "align": "full"
      }
    },
    "diagram-heading": {
      "@type": "slate",
      "plaintext": "Architecture Overview",
      "value": [
