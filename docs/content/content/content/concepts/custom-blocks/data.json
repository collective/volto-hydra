    "p-11": {
      "@type": "slate",
      "plaintext": "`fieldMappings` (plural) on a block config defines how fields map between block types. This enables three things:",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "fieldMappings",
              "code": true
            },
            {
              "text": " (plural) on a block config defines how fields map between block types. This enables three things:"
            }
          ]
        }
      ]
    },
    "ul-12": {
      "@type": "slate",
      "plaintext": "\"Convert to...\" UI action — editors can convert a block to another type (e.g. teaser → image). Listing item types — query results are mapped to item blocks via @default (see Listings). Synchronised container children — a parent controls child type, all children convert together (see Container Blocks › Synchronised Block Types).",
      "value": [
        {
          "type": "ul",
          "children": [
            {
              "type": "li",
              "children": [
                {
                  "text": "\"Convert to...\" UI action",
                  "strong": true
                },
                {
                  "text": " — editors can convert a block to another type (e.g. teaser → image)."
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Listing item types",
                  "strong": true
                },
                {
                  "text": " — query results are mapped to item blocks via "
                },
                {
                  "text": "@default",
                  "code": true
                },
                {
                  "text": " (see "
                },
                {
                  "type": "link",
                  "data": {
                    "url": "listings.md"
                  },
                  "children": [
                    {
                      "text": "Listings"
                    }
                  ]
                },
                {
                  "text": ")."
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Synchronised container children",
                  "strong": true
                },
                {
                  "text": " — a parent controls child type, all children convert together (see "
                },
                {
                  "type": "link",
                  "data": {
                    "url": "container-blocks.md#synchronised-block-types-in-a-container"
                  },
                  "children": [
                    {
                      "text": "Container Blocks › Synchronised Block Types"
                    }
                  ]
                },
                {
                  "text": ")."
                }
              ]
            }
          ]
        }
      ]
    },
