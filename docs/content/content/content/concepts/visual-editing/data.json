  "blocks": {
    "annotations-heading": {
      "@type": "slate",
      "plaintext": "HTML Annotations for Visual Editing",
      "value": [
        {
          "children": [
            {
              "text": "HTML Annotations for Visual Editing"
            }
          ],
          "type": "h2"
        }
      ]
    },
    "annotations-text-t0": {
      "@type": "slate",
      "plaintext": "Add data attributes to your rendered HTML to enable progressively richer visual editing: data-block-uid=\"blockId\" \u2014 Click-to-select blocks. Hydra.js adds click handlers and shows a blue outline and Quanta toolbar on selected blocks.data-edit-text=\"fieldName\" \u2014 Inline text editing. For simple text, click and type directly. For rich text (slate widget), select text to apply formatting via the Quanta toolbar.data-edit-media=\"fieldName\" \u2014 Visual media uploading. Editors can upload, pick or drag-and-drop images directly onto the element.data-edit-link=\"fieldName\" \u2014 Link editing. Click behaviour is replaced with a link picker to select content, enter an external URL, or open the link. Example of a fully annotated slide block:",
      "value": [
        {
          "children": [
            {
              "text": "Add data attributes to your rendered HTML to enable progressively richer visual editing:"
            }
          ],
          "type": "p"
        },
        {
          "children": [
            {
              "children": [
                {
                  "children": [
                    {
                      "text": "data-block-uid=\"blockId\""
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " \u2014 Click-to-select blocks. Hydra.js adds click handlers and shows a blue outline and Quanta toolbar on selected blocks."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "children": [
                    {
                      "text": "data-edit-text=\"fieldName\""
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " \u2014 Inline text editing. For simple text, click and type directly. For rich text (slate widget), select text to apply formatting via the Quanta toolbar."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "children": [
                    {
                      "text": "data-edit-media=\"fieldName\""
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " \u2014 Visual media uploading. Editors can upload, pick or drag-and-drop images directly onto the element."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "children": [
                    {
                      "text": "data-edit-link=\"fieldName\""
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " \u2014 Link editing. Click behaviour is replaced with a link picker to select content, enter an external URL, or open the link."
                }
              ],
              "type": "li"
            }
          ],
          "type": "ul"
        },
        {
          "children": [
            {
              "text": "Example of a fully annotated slide block:"
            }
          ],
          "type": "p"
        }
      ]
    },
    "annotations-text-c1": {
      "@type": "codeExample",
      "tabs": [
        {
          "@id": "annotations-text-c1-html-414f7f",
          "label": "HTML",
          "language": "html",
          "code": "<div class=\"slide\" data-block-uid=\"slide-1\">\n    <img data-edit-media=\"image\" src=\"/big_news.jpg\"/>\n    <h2 data-edit-text=\"title\">Big News</h2>\n    <div data-edit-text=\"description\">\n        Check out <b>hydra</b>, it will change everything\n    </div>\n    <a data-edit-link=\"url\"\n       data-edit-text=\"buttonText\"\n       href=\"/big_news\">Read more</a>\n</div>"
        }
      ]
    },
    "comment-heading": {
      "@type": "slate",
      "plaintext": "Comment Syntax",
