      ]
    },
    "comment-text-t0": {
      "@type": "slate",
      "plaintext": "If you can't modify the markup (e.g., using a 3rd party component library), use comment syntax to specify block attributes:",
      "value": [
        {
          "children": [
            {
              "text": "If you can't modify the markup (e.g., using a 3rd party component library), use comment syntax to specify block attributes:"
            }
          ],
          "type": "p"
        }
      ]
    },
    "comment-text-c1": {
      "@type": "codeExample",
      "tabs": [
        {
          "@id": "comment-text-c1-html-06720d",
          "label": "HTML",
          "language": "html",
          "code": "<!-- hydra block-uid=block-123\n     edit-text=title(.card-title)\n     edit-media=url(img)\n     edit-link=href(a.link) -->\n<div class=\"third-party-card\">\n  <h3 class=\"card-title\">Title</h3>\n  <img src=\"image.jpg\">\n  <a class=\"link\" href=\"...\">Read more</a>\n</div>\n<!-- /hydra -->"
        }
      ]
    },
    "comment-text-t2": {
      "@type": "slate",
      "plaintext": "Attributes without selectors apply to the root element: block-uid=xxxAttributes with selectors target child elements: edit-text=title(.card-title)Closing <!-- /hydra --> marks end of scopeSelf-closing <!-- hydra block-uid=xxx /--> applies only to next sibling element Supported attributes: block-uid, block-readonly, edit-text, edit-link, edit-media, block-add",
      "value": [
        {
          "children": [
            {
              "children": [
                {
                  "text": "Attributes without selectors apply to the root element: block-uid=xxx"
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Attributes with selectors target child elements: edit-text=title(.card-title)"
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Closing <!-- /hydra --> marks end of scope"
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Self-closing <!-- hydra block-uid=xxx /--> applies only to next sibling element"
                }
              ],
              "type": "li"
            }
          ],
          "type": "ul"
        },
        {
          "children": [
            {
              "text": "Supported attributes: block-uid, block-readonly, edit-text, edit-link, edit-media, block-add"
            }
          ],
          "type": "p"
        }
      ]
    },
