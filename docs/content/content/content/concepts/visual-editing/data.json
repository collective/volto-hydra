    "pathsyntax-text-t0": {
      "@type": "slate",
      "plaintext": "The data-edit-text|edit-media|edit-link attributes support Unix-style paths to edit fields outside the current block: fieldName \u2014 edit the block's own field (default)../fieldName \u2014 edit the parent block's field../../fieldName \u2014 edit the grandparent's field/fieldName \u2014 edit the page metadata field",
      "value": [
        {
          "children": [
            {
              "text": "The data-edit-text|edit-media|edit-link attributes support Unix-style paths to edit fields outside the current block:"
            }
          ],
