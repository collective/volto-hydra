  "blocks": {
    "quickstart-heading": {
      "@type": "slate",
      "plaintext": "Quick Start",
      "value": [
        {
          "children": [
            {
              "text": "Quick Start"
            }
          ],
          "type": "h2"
        }
      ]
    },
    "quickstart-text": {
      "@type": "slate",
      "plaintext": "Try the online demo at hydra.pretagov.com. Or run locally: clone the repo, start Plone, start a frontend, start Hydra.",
      "value": [
        {
          "children": [
            {
              "text": "Try the "
            },
            {
              "children": [
                {
                  "text": "online demo"
                }
              ],
              "data": {
                "url": "https://hydra.pretagov.com"
              },
              "type": "link"
            },
            {
              "text": " — log in, go to user preferences and select a preset frontend or paste in your own frontend URL."
            }
          ],
          "type": "p"
        },
        {
          "children": [
            {
              "text": "To make your own site editable with Hydra, add the hydra.js bridge to your frontend and annotate your HTML with block markers:"
            }
          ],
          "type": "p"
        },
        {
          "children": [
            {
              "children": [
                {
                  "text": "Load "
                },
                {
                  "children": [
                    {
                      "text": "hydra.js"
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " and call initBridge() with your block configuration"
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Add "
                },
                {
                  "children": [
                    {
                      "text": "data-block-uid"
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " attributes to enable click-to-select blocks"
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Register "
                },
                {
                  "children": [
                    {
                      "text": "onEditChange"
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " callback for realtime preview updates"
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Add "
                },
                {
                  "children": [
                    {
                      "text": "data-editable-field"
                    }
                  ],
                  "type": "strong"
                },
                {
                  "text": " for inline text, media and link editing"
                }
              ],
              "type": "li"
            }
          ],
          "type": "ol"
        }
      ]
    },
    "0ab1a8f7-2d26-4933-800c-2f10474afe63": {
      "@type": "separator",
      "styles": {
        "align": "full"
      }
    },
    "0c91e9dd-842e-4764-a4f1-8a62c85b731a": {
      "@type": "slate",
      "plaintext": "Quick to enable Visual editing of frontend blocks regardless of framework. Switch between multiple frontends mid visual edit. Enterprise features such as versioning, i18n, workflow and automated content rules. Customisable Administration Interface. Scalable and Secure with a mature battle hardened backend. Open source means flexibility to host where and how you want.",
      "styles": {},
      "value": [
        {
          "children": [
            {
              "children": [
                {
                  "text": "Quick to enable Visual editing of frontend blocks regardless of framework by just using tags. No required React or Vue in your frontend."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Switch between multiple frontends mid visual edit. Perfect for omni-channel."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Enterprise features such as versioning, i18n, workflow and automated content rules."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Easier to implement design systems that enforce governance of content and design."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Customisable Administration Interface. Choice of Python or JavaScript for your server."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Scalable and Secure with a mature battle hardened backend."
                }
              ],
              "type": "li"
            },
            {
              "children": [
                {
                  "text": "Open source means flexibility to host where and how you want and optimise costs and security."
                }
              ],
              "type": "li"
            }
          ],
          "type": "ul"
        }
      ]
    },
