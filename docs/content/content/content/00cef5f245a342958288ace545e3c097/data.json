      "tabs": [
        {
          "@id": "ref-introduction-rendering-jsx-599242",
          "label": "React",
          "language": "jsx",
          "code": "function IntroductionBlock({ block }) {\n  return (\n    <div data-block-uid={block['@uid']} className=\"introduction-block\" data-edit-text=\"value\">\n      {(block.value || []).map((node, i) => (\n        <SlateNode key={i} node={node} />\n      ))}\n    </div>\n  );\n}"
        },
        {
          "@id": "ref-introduction-rendering-vue-53106b",
          "label": "Vue",
          "language": "vue",
          "code": "<template>\n  <div :data-block-uid=\"block['@uid']\" class=\"introduction-block\" data-edit-text=\"value\">\n    <SlateNode v-for=\"(node, i) in block.value || []\" :key=\"i\" :node=\"node\" />\n  </div>\n</template>\n\n<script setup>\ndefineProps({ block: Object });\n</script>"
        },
        {
          "@id": "ref-introduction-rendering-svelte-9e2b59",
          "label": "Svelte",
          "language": "svelte",
          "code": "<script>\n  import SlateNode from './SlateNode.svelte';\n  export let block;\n</script>\n\n<div data-block-uid={block['@uid']} class=\"introduction-block\" data-edit-text=\"value\">\n  {#each block.value || [] as node, i (i)}\n    <SlateNode {node} />\n  {/each}\n</div>"
        }
      ]
