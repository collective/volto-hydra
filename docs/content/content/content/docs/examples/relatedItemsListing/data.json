          "@id": "ref-relatedItemsListing-rendering-javascript-2b9d44",
          "label": "Register",
          "language": "javascript",
          "code": "fetchItems: { relatedItemsListing: relatedItemsFetcher({ apiUrl, contextPath }) }"
        }
