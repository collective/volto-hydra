    "ref-relatedItemsListing-fetcher": {
      "@type": "codeExample",
      "templateId": "/templates/block-reference-layout",
      "templateInstanceId": "tpl-inst-relatedItemsListing",
      "slotId": "rendering",
      "tabs": [
        {
          "@id": "ref-relatedItemsListing-fetcher-javascript-1c975d",
          "label": "Fetcher",
          "language": "javascript",
          "code": "export function relatedItemsFetcher({ apiUrl, contextPath }) {\n  return async function fetchItems(block, { start, size }) {\n    const field = block.relationField || 'relatedItems';\n    const content = await (await fetch(`${apiUrl}${contextPath}/++api++`, { headers: authHeaders() })).json();\n    const all = Array.isArray(content[field]) ? content[field] : [];\n    return { items: all.slice(start, start + size), total: all.length };\n  };\n}"
        }
      ]
    },
