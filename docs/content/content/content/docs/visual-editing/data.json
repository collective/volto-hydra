    "ul-9": {
      "@type": "slate",
      "plaintext": "Attributes without selectors apply to the root element: block-uid=xxx Attributes with selectors target child elements: edit-text=title(.card-title) Closing <!-- /hydra --> marks end of scope Self-closing <!-- hydra block-uid=xxx /--> applies only to next sibling element",
      "value": [
        {
          "type": "ul",
          "children": [
            {
              "type": "li",
              "children": [
                {
                  "text": "Attributes without selectors apply to the root element: "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "block-uid=xxx"
                    }
                  ]
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Attributes with selectors target child elements: "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "edit-text=title(.card-title)"
                    }
                  ]
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Closing "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "<!-- /hydra -->"
                    }
                  ]
                },
                {
                  "text": " marks end of scope"
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Self-closing "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "<!-- hydra block-uid=xxx /-->"
                    }
                  ]
                },
                {
                  "text": " applies only to next sibling element"
                }
              ]
            }
          ]
        }
      ]
    },
