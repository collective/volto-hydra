  "blocks": {
    "title-1": {
      "@type": "title"
    },
    "p-1": {
      "@type": "slate",
      "plaintext": "The block chooser, slash menu, and drag handles are part of Hydra and look the same everywhere. What you can pick from those choosers — the list of block types — comes from your site's design system. One site might offer \"Lead paragraph\", \"Pull quote\", \"Stat highlight\"; another might just have \"Text\" and \"Image\". Mechanic is identical.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "The block chooser, slash menu, and drag handles are part of Hydra and look the same everywhere. What you can pick from those choosers — the list of block types — comes from your site's design system. One site might offer \"Lead paragraph\", \"Pull quote\", \"Stat highlight\"; another might just have \"Text\" and \"Image\". Mechanic is identical."
            }
          ]
        }
      ]
    },
    "h-2": {
      "@type": "slate",
      "plaintext": "Adding a block",
      "value": [
        {
          "type": "h2",
          "children": [
            {
              "text": "Adding a block"
            }
          ]
        }
      ]
    },
    "p-3": {
      "@type": "slate",
      "plaintext": "Three ways:",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Three ways:"
            }
          ]
        }
      ]
    },
    "h-4": {
      "@type": "slate",
      "plaintext": "\"+\" button in the preview",
      "value": [
        {
          "type": "h3",
          "children": [
            {
              "text": "\"+\" button in the preview"
            }
          ]
        }
      ]
    },
    "p-5": {
      "@type": "slate",
      "plaintext": "Hover or select a block in the preview. A \"+\" button appears outside one corner of it (typically below for vertical layouts, to the right for horizontal). Click it to open the **block chooser** — a popup listing the block types allowed at that position.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Hover or select a block in the preview. A \"+\" button appears outside one corner of it (typically below for vertical layouts, to the right for horizontal). Click it to open the "
            },
            {
              "type": "strong",
              "children": [
                {
                  "text": "block chooser"
                }
              ]
            },
            {
              "text": " — a popup listing the block types allowed at that position."
            }
          ]
        }
      ]
    },
    "p-6": {
      "@type": "slate",
      "plaintext": "The chooser is filtered: it only shows block types that fit the surrounding container's `allowedBlocks`. Block types are grouped (Common, Site, Custom, Templates) and typically a \"Most used\" group is pinned to the top.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "The chooser is filtered: it only shows block types that fit the surrounding container's "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "allowedBlocks"
                }
              ]
            },
            {
              "text": ". Block types are grouped (Common, Site, Custom, Templates) and typically a \"Most used\" group is pinned to the top."
            }
          ]
        }
      ]
    },
    "h-7": {
      "@type": "slate",
      "plaintext": "Slash menu (in an empty text block)",
      "value": [
        {
          "type": "h3",
          "children": [
            {
              "text": "Slash menu (in an empty text block)"
            }
          ]
        }
      ]
    },
    "p-8": {
      "@type": "slate",
      "plaintext": "Type `/` at the start of an empty text block (a fresh paragraph or a paragraph you've cleared). The slash menu opens with the list of block types you can convert to. Keep typing to filter; `Enter` picks; `Escape` dismisses.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Type "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "/"
                }
              ]
            },
            {
              "text": " at the start of an empty text block (a fresh paragraph or a paragraph you've cleared). The slash menu opens with the list of block types you can convert to. Keep typing to filter; "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "Enter"
                }
              ]
            },
            {
              "text": " picks; "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "Escape"
                }
              ]
            },
            {
              "text": " dismisses."
            }
          ]
        }
      ]
    },
    "p-9": {
      "@type": "slate",
      "plaintext": "This is the fastest way to add a heading, image, embed, or other block while you're already typing — no mouse needed.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "This is the fastest way to add a heading, image, embed, or other block while you're already typing — no mouse needed."
            }
          ]
        }
      ]
    },
    "h-10": {
      "@type": "slate",
      "plaintext": "Enter from a selected block (block mode)",
      "value": [
        {
          "type": "h3",
          "children": [
            {
              "text": "Enter from a selected block (block mode)"
            }
          ]
        }
      ]
    },
    "p-11": {
      "@type": "slate",
      "plaintext": "Press `Escape` to enter block mode, then `Enter`. A new block is created **after** the current one, of the most appropriate default type (or the only type allowed in the current container if there's just one).",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Press "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "Escape"
                }
              ]
            },
            {
              "text": " to enter block mode, then "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "Enter"
                }
              ]
            },
            {
              "text": ". A new block is created "
            },
            {
              "type": "strong",
              "children": [
                {
                  "text": "after"
                }
              ]
            },
            {
              "text": " the current one, of the most appropriate default type (or the only type allowed in the current container if there's just one)."
            }
          ]
        }
      ]
    },
    "p-12": {
      "@type": "slate",
      "plaintext": "If the current block is itself a container, `Enter` creates a new container of the same type and the cursor lands inside it on the first typeable leaf — so you can keep typing without aiming. Useful for sliders, columns, accordions: hit `Enter` once and you're already in the next slide / column / panel.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "If the current block is itself a container, "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "Enter"
                }
              ]
            },
            {
              "text": " creates a new container of the same type and the cursor lands inside it on the first typeable leaf — so you can keep typing without aiming. Useful for sliders, columns, accordions: hit "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "Enter"
                }
              ]
            },
            {
              "text": " once and you're already in the next slide / column / panel."
            }
          ]
        }
      ]
    },
