                  "text": "findChangedUnit(prevFormData, newFormData)"
                }
              ]
            },
            {
              "text": " walks the new form data against the previous one looking for the shallowest changed subtree. At each container level:"
            }
          ]
        }
      ]
    },
    "ul-10": {
      "@type": "slate",
      "plaintext": "items array differs (add/remove/reorder) → this container is the unit exactly one child differs AND items unchanged → recurse into that child 2 or more children differ → this container is the unit nothing differs → no-op (forms are equal)",
      "value": [
        {
          "type": "ul",
          "children": [
            {
              "type": "li",
              "children": [
                {
                  "type": "code",
                  "children": [
