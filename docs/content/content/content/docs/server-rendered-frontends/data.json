    "p-1": {
      "@type": "slate",
      "plaintext": "Hydra works with any frontend, including ones that have no client-side reactivity at all — pure server-rendered frameworks like **Astro**, **PHP**, **Django**, **Rails**, **Laravel**, **Symfony**, **Go html/template**. The bridge ships a built-in pattern for these: one config option on `initBridge` and one small endpoint on your server.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Hydra works with any frontend, including ones that have no client-side reactivity at all — pure server-rendered frameworks like "
            },
            {
              "type": "strong",
              "children": [
                {
                  "text": "Astro"
                }
              ]
            },
            {
              "text": ", "
            },
            {
              "type": "strong",
              "children": [
                {
                  "text": "PHP"
                }
              ]
            },
            {
              "text": ", "
            },
            {
