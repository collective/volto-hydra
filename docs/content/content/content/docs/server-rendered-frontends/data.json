          "code": "<!-- blocks/_renderer.php — enforces the data-block-uid contract -->\n<div data-block-uid=\"<?= htmlspecialchars($block['@uid']) ?>\">\n  <?php\n    $tpl = __DIR__ . \"/{$block['@type']}.php\";\n    if (file_exists($tpl)) include $tpl;\n  ?>\n</div>"
