                  ]
                },
                {
                  "text": " array differs (add/remove/reorder) → "
                },
                {
                  "type": "strong",
                  "children": [
                    {
                      "text": "this container is the unit"
                    }
                  ]
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "exactly one child differs AND "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "items"
                    }
                  ]
                },
                {
                  "text": " unchanged → recurse into that child"
                }
              ]
            },
            {
              "type": "li",
              "children": [
