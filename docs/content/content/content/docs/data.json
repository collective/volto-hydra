    "p-1": {
      "@type": "slate",
      "plaintext": "A Visual Headless CMS using Plone as a server, providing true visual editing with drag-and-drop blocks and editable text — with any frontend stack you choose.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "A Visual Headless CMS using Plone as a server, providing true visual editing with drag-and-drop blocks and editable text — with any frontend stack you choose."
            }
          ]
        }
      ]
    },
    "h-2": {
      "@type": "slate",
      "plaintext": "Why Hydra?",
      "value": [
        {
          "type": "h2",
          "children": [
            {
              "text": "Why Hydra?"
            }
          ]
        }
      ]
    },
    "ul-3": {
      "@type": "slate",
      "plaintext": "Visual + True Headless + Open Source — a unique combination in the CMS space Framework agnostic — use Next.js, Nuxt.js, Astro, or any frontend stack Quick visual editing — enable it with simple HTML data attributes, no React or Vue required in your frontend Omni-channel — switch between multiple frontends mid-edit Enterprise features — versioning, i18n, workflow, and automated content rules Customisable — both the admin interface and block definitions are fully configurable",
      "value": [
        {
          "type": "ul",
          "children": [
            {
              "type": "li",
              "children": [
                {
                  "text": "Visual + True Headless + Open Source",
                  "strong": true
                },
                {
                  "text": " — a unique combination in the CMS space"
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Framework agnostic",
                  "strong": true
                },
                {
                  "text": " — use Next.js, Nuxt.js, Astro, or any frontend stack"
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Quick visual editing",
                  "strong": true
                },
                {
                  "text": " — enable it with simple HTML data attributes, no React or Vue required in your frontend"
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Omni-channel",
                  "strong": true
                },
                {
                  "text": " — switch between multiple frontends mid-edit"
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Enterprise features",
                  "strong": true
                },
                {
                  "text": " — versioning, i18n, workflow, and automated content rules"
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Customisable",
                  "strong": true
                },
                {
                  "text": " — both the admin interface and block definitions are fully configurable"
                }
              ]
            }
          ]
        }
      ]
    },
    "h-4": {
      "@type": "slate",
      "plaintext": "Try the online demo",
      "value": [
        {
          "type": "h2",
          "children": [
            {
              "text": "Try the online demo"
            }
          ]
        }
      ]
    },
    "p-5": {
      "@type": "slate",
      "plaintext": "The fastest way to feel what Hydra does is to log into the hosted demo and edit a real page against a real frontend.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "The fastest way to feel what Hydra does is to log into the hosted demo and edit a real page against a real frontend."
            }
          ]
        }
      ]
    },
    "p-6": {
      "@type": "slate",
      "plaintext": "Open <https://hydra.pretagov.com>, log in, then:",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Open <https://hydra.pretagov.com>, log in, then:"
            }
          ]
        }
      ]
    },
    "ul-7": {
      "@type": "slate",
      "plaintext": "Open user preferences (bottom-left). Pick one of the preset frontends, or paste in your own frontend URL. Edit any page — every change updates the live preview.",
