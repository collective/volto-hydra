                    }
                  ]
                },
                {
                  "text": ", "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "data-edit-text"
                    }
                  ]
                },
                {
                  "text": ", "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "data-edit-link"
                    }
                  ]
                },
                {
                  "text": ", "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "data-edit-media"
                    }
                  ]
                },
                {
                  "text": ", "
                },
                {
                  "type": "code",
                  "children": [
                    {
                      "text": "data-node-id"
                    }
                  ]
                },
                {
                  "text": ")."
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "text": "Captures pointer events through invisible elements so the admin's chrome stays interactive."
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
