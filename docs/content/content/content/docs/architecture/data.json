    "title-1": {
      "@type": "title"
    },
    "p-1": {
      "@type": "slate",
      "plaintext": "Instead of combining editing and rendering into one framework and codebase, these are separated and during editing a two way communication channel is opened across an iframe so that the editing UI is no longer part of the frontend code. Instead a small JS file called hydra.js is included in your frontend during editing that handles the iframe bridge communication to Hydra which is running in the same browser window.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "Instead of combining editing and rendering into one framework and codebase, these are separated and during editing a two way communication channel is opened across an iframe so that the editing UI is no longer part of the frontend code. Instead a small JS file called hydra.js is included in your frontend during editing that handles the iframe bridge communication to Hydra which is running in the same browser window."
            }
          ]
        }
      ]
    },
    "sep-2": {
      "@type": "separator"
    },
    "h-3": {
      "@type": "slate",
      "plaintext": "Architecture Overview",
      "value": [
        {
          "type": "h2",
          "children": [
            {
              "text": "Architecture Overview"
            }
          ]
        }
      ]
    },
    "p-4": {
      "@type": "slate",
      "plaintext": "You could think of it as splitting Volto into two parts, Rendering and CMS UI/Admin UI while keeping the same UI and then making the Rendering part easily replaceable with other implementations.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "You could think of it as splitting Volto into two parts, Rendering and CMS UI/Admin UI while keeping the same UI and then making the Rendering part easily replaceable with other implementations."
            }
          ]
        }
      ]
    },
    "ce-5": {
      "@type": "codeExample",
      "tabs": [
        {
          "@id": "ce-5-bash-56c4ae",
          "label": "Architecture",
          "language": "bash",
          "code": "                  Browser            RestAPI             Server\n\n              ┌──────────────┐                       ┌─────────────┐\n Anon/Editing │    Volto     │◄─────────────────────►│    Plone    │\n              └──────────────┘                       └─────────────┘\n\n──────────────────────────────────────────────────────────────────────────\n\n          │   ┌──────────────┐                       ┌─────────────┐\n          │   │   Frontend   │◄──────────────────────┤    Plone    │\n          │   └──hydra.js────┘                       └─────────────┘\n          │          ▲                                  ▲\n Editing UI          │ iFrame Bridge                    │\n          │          ▼                                  │\n          │   ┌──────────────┐                          │\n          │   │    Hydra     │◄─────────────────────────┘\n          │   └──────────────┘\n\n              ┌──────────────┐                       ┌─────────────┐\n Anon         │   Frontend   │◄──────────────────────┤    Plone    │\n              └──────────────┘                       └─────────────┘"
        }
      ]
    },
    "h-6": {
      "@type": "slate",
      "plaintext": "The iframe ↔ admin bridge",
      "value": [
        {
          "type": "h2",
          "children": [
            {
              "text": "The iframe ↔ admin bridge"
            }
          ]
        }
      ]
    },
    "p-7": {
      "@type": "slate",
      "plaintext": "During editing the frontend is loaded inside an iframe owned by Hydra's admin UI. The two communicate via `postMessage` over the iframe boundary:",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "During editing the frontend is loaded inside an iframe owned by Hydra's admin UI. The two communicate via "
            },
            {
              "type": "code",
              "children": [
                {
                  "text": "postMessage"
                }
              ]
            },
            {
              "text": " over the iframe boundary:"
            }
          ]
        }
      ]
    },
    "ul-8": {
      "@type": "slate",
      "plaintext": "Admin → frontend: form-data updates, selection changes, route changes. Frontend → admin: which block was clicked (selection), which slate node holds the cursor, where blocks live in the rendered DOM, slate transform requests so the admin can compute the new value.",
      "value": [
        {
          "type": "ul",
          "children": [
            {
              "type": "li",
              "children": [
                {
                  "type": "strong",
                  "children": [
                    {
                      "text": "Admin → frontend"
                    }
                  ]
                },
                {
                  "text": ": form-data updates, selection changes, route changes."
                }
              ]
            },
            {
              "type": "li",
              "children": [
                {
                  "type": "strong",
                  "children": [
                    {
                      "text": "Frontend → admin"
                    }
                  ]
                },
                {
                  "text": ": which block was clicked (selection), which slate node holds the cursor, where blocks live in the rendered DOM, slate transform requests so the admin can compute the new value."
                }
              ]
            }
          ]
        }
      ]
    },
    "p-9": {
      "@type": "slate",
      "plaintext": "This split lets the frontend stay 100% headless when not in admin (just renders content), while the admin gets full visual editing without the frontend having to know any React, any block-form widgets, or any sidebar UI.",
      "value": [
        {
          "type": "p",
          "children": [
            {
              "text": "This split lets the frontend stay 100% headless when not in admin (just renders content), while the admin gets full visual editing without the frontend having to know any React, any block-form widgets, or any sidebar UI."
            }
          ]
        }
      ]
    },
    "h-10": {
