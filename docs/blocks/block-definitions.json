            "@id": "field-1",
            "field_id": "name",
            "field_type": "text",
            "label": "Your Name",
            "required": true
          },
          {
            "@id": "field-2",
            "field_id": "email",
            "field_type": "from",
            "label": "Email Address",
            "use_as_reply_to": true,
            "required": true
          },
          {
            "@id": "field-3",
            "field_id": "department",
            "field_type": "select",
            "label": "Department",
            "input_values": [
